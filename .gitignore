# Patient data - NEVER commit
reports/
inputs/
annotation/

# Test data (large BAM files)
testdata/*.bam
testdata/*.bam.bai
testdata/*.bai

# Environment
.env
.env.*

# R targets cache
_targets/

# API response cache (OncoKB / CiVIC / PubMed live answers — may carry
# tumor-type-resolved annotations tied to a patient sample)
.api_cache/
reports/.oncokb_cache/
reports/.openevidence_cache/

# Netlify CLI working directory (per-machine deploy state)
.netlify/

# Per-machine Claude Code settings + agent transcripts
.claude/settings.local.json
.claude/transcripts/
.claude/scheduled_tasks.lock

# Raw patient-data uploads (zips of TSO500 deliverables)
TSO500*.zip
TSO500HRD*.zip

# Personal/private plan files
*.private.md

# Agent runtime: inputs, outputs, and logs may contain prompts/responses;
# treat as patient-adjacent even in benchmarks
agents/inputs/
agents/outputs/
agents/logs/

# Tools directory (GATK, VEP)
tools/

# renv library (lockfile is committed)
renv/library/
renv/staging/
renv/cellar/
renv/sandbox/

# R artifacts
.Rhistory
.Rdata
.RData
*.Rproj.user

# OS
.DS_Store
Thumbs.db

# Quarto render artifacts
*_files/
*.html
!docs/index.html
!08-report/partials/*.qmd
benchmarks/results/clinvar/
benchmarks/datasets/seqc2/*.vcf.gz
benchmarks/datasets/seqc2/*.tbi
